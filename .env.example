# ─── AI Providers ────────────────────────────────────────────────────────────
# The backend is provider-agnostic. You can run 100% free using Gemini.
# Set AI_PROVIDER_* to choose which provider handles each feature.

# TODO(human:gemini-api-key) — FREE, no credit card required.
# Get yours at: https://aistudio.google.com
GEMINI_API_KEY=

# TODO(human:anthropic-api-key) — Optional/paid. Only needed if AI_PROVIDER_ASSESSMENT=claude.
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# TODO(human:openrouter-api-key) — OpenRouter key (default provider for the assessment).
# Get yours at: https://openrouter.ai/keys  (pay-as-you-go, ~$0.10–0.60 per 1M tokens)
# Data policy: OpenRouter does NOT train on API requests — safe for EU business leads.
OPENROUTER_API_KEY=

# OpenRouter model used for the assessment.
# Default: meta-llama/llama-3.1-70b-instruct (capable, cheap, no training on requests).
# Change to any OpenRouter model ID; see openrouter.ai/models for options.
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# Provider selection — change these to switch features between providers.
# Assessment: 'openrouter' (default, pay-as-you-go), 'claude' (paid), or 'gemini' (free but EU data caveat).
# Chatbot: 'gemini' (free) — Phase 3.
# See README for the full EU data-privacy note.
AI_PROVIDER_CHATBOT=gemini
AI_PROVIDER_ASSESSMENT=openrouter

# ─── Internal drafting helper ────────────────────────────────────────────────
# TODO(human:draft-secret) — Any random string you choose. Protects /api/draft from
# public use. Example: openssl rand -hex 32
# See README "How to add a blog post" for usage instructions.
DRAFT_SECRET=

# ─── Email / Leads ────────────────────────────────────────────────────────────
# TODO(human:resend-api-key) — Resend free tier (3,000 emails/month).
# Get yours at: https://resend.com
RESEND_API_KEY=

# Email address that receives all form submissions (contact, partner, careers).
LEADS_NOTIFY_EMAIL=info@karagateway.com

# "From" address on outgoing lead emails.
# IMPORTANT — delivery only works if this domain is verified in Resend:
#   resend.com dashboard → Domains → Add Domain → karagateway.com → add SPF + DKIM records.
# Until the domain is verified, emails can only deliver to the Resend account owner's
# email address, not to info@karagateway.com. Set this AFTER verifying the domain.
RESEND_FROM_EMAIL=noreply@karagateway.com

# ─── Booking ─────────────────────────────────────────────────────────────────
# TODO(human:calcom-link) — Your Cal.com or Calendly booking URL.
# Example: https://cal.com/yourname/consultation
NEXT_PUBLIC_CALCOM_LINK=

# Your canonical site URL (used for OpenGraph / SEO).
NEXT_PUBLIC_SITE_URL=https://www.karagateway.com
